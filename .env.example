# =============================================
# AEGIS-IMINT — Configuración de entorno
# Copia este archivo a .env y rellena los valores
# NUNCA subas .env a git (ya está en .gitignore)
# =============================================

# --- Sentinel Hub (requerido para imágenes reales) ---
# Crea cuenta gratuita en https://www.sentinel-hub.com/
SENTINEL_INSTANCE_ID=tu_instance_id
SENTINEL_CLIENT_ID=tu_client_id
SENTINEL_CLIENT_SECRET=tu_client_secret
SENTINEL_RESOLUTION=10

# --- Modelo YOLO ---
# Coloca tu modelo entrenado en la carpeta modelos/
# Ver modelos/README.md para instrucciones de obtención
YOLO_MODEL_PATH=modelos/yolov8_military.pt
CONFIDENCE_THRESHOLD=0.45

# --- Ollama (local, opcional pero recomendado) ---
# Instala Ollama: https://ollama.ai/
# Descarga el modelo: ollama pull llava:7b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llava:7b

# --- Alertas Email (opcional) ---
# Para Gmail usa una "App Password" (no tu contraseña normal)
# https://myaccount.google.com/apppasswords
EMAIL_FROM=tu_email@gmail.com
EMAIL_PASSWORD=tu_app_password_gmail
EMAIL_TO=comandante@ejemplo.com
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587

# --- Alertas Telegram (opcional) ---
# Crea un bot con @BotFather en Telegram
TELEGRAM_BOT_TOKEN=tu_bot_token
TELEGRAM_CHAT_ID=tu_chat_id

# --- Parámetros de monitoreo ---
UPDATE_INTERVAL=3600
SENSIBILIDAD_ALERTA=5
MAX_IMAGE_AGE_DAYS=3

# --- Almacenamiento y seguridad ---
DB_PATH=base_de_datos/detecciones.db
IMAGES_DIR=imagenes
FERNET_KEY_PATH=base_de_datos/.fernet_key
